# Existing Django settings are omitted here; copy the values from the hosting
# environment and add the rate-limit settings below.

# off -> observe -> enforce. Start production rollout in observe mode.
RATE_LIMIT_MODE=observe
RATE_LIMIT_REDIS_URL=rediss://user:password@redis.example.com:6379/1

# Optional during staged enforcement. Empty means every configured scope.
# Start with sensitive scopes, then remove this setting to enforce all limits.
# RATE_LIMIT_ENFORCE_SCOPES=login_ip,login_identifier,admin_login_ip,admin_login_identifier,signup_ip,signup_email,otp_send_ip,otp_send_identifier,otp_verify_ip,otp_verify_identifier,refresh_ip,refresh_token,order_create_user,upload_user,notification_send_user

# Use the header supplied by the current ingress. It is trusted only when the
# socket peer belongs to one of these proxy networks.
RATE_LIMIT_CLIENT_IP_HEADER=DO-Connecting-IP
RATE_LIMIT_TRUSTED_PROXY_CIDRS=10.0.0.0/8

# Use a separate random secret so Redis identities cannot be reversed.
RATE_LIMIT_KEY_SECRET=replace-with-a-long-random-secret
RATE_LIMIT_EXEMPT_PATHS=/health/,/healthz/,/readyz/

RATE_LIMIT_CONNECT_TIMEOUT=0.5
RATE_LIMIT_SOCKET_TIMEOUT=0.2
RATE_LIMIT_MAX_CONNECTIONS=20
RATE_LIMIT_HEALTH_CHECK_INTERVAL=30
RATE_LIMIT_LOG_SAMPLE_RATE=0.1

# Optional examples. Every scope can be overridden without a code deploy.
# RATE_LIMIT_LOGIN_IDENTIFIER_RATES=5/5m,20/1h
# RATE_LIMIT_API_USER_RATES=600/5m
